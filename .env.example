# --- Mintrud Admin environment template ---
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# .env is gitignored; never commit it. docker-compose.yml reads it via
# env_file: and forwards every MINTRUD_ADMIN_* variable to the container.

# --- Required: bootstrap admin password ---
# Used exactly once, on first start, to seed the operator account. After
# that the admin logs in with the password they set (via /admin/users,
# post-MVP) and the env var is ignored. Pick a strong value — there is
# no autogeneration and no log line is ever printed.
MINTRUD_ADMIN_BOOTSTRAP_PASSWORD=change-me-before-first-start

# --- Optional: HTTP listen address ---
# Default in code is ":8080". Set to ":80" or a unix socket only if you
# know what you are doing; for production, terminate TLS in front of the
# app and bind on a high port behind a reverse proxy.
# MINTRUD_ADMIN_ADDR=:8080

# --- Optional: SQLite database path inside the container ---
# Default is data/mintrud-admin.db relative to the binary's working
# directory, which is /app in the runtime image. The docker-compose
# volume mounts /app/data, so the default path lands inside the named
# volume. Override only if you change the volume mount.
# MINTRUD_ADMIN_DB=/app/data/mintrud-admin.db

# --- Optional: session TTL ---
# Go duration string. Default 8h. Shorter values are safer; longer
# values are more convenient. The CSRF token TTL inherits from this.
# MINTRUD_ADMIN_SESSION_TTL=8h

# --- Optional: secure cookies ---
# Set to "true" in production (HTTPS). Local dev over plain http must
# leave this at "false" or the browser will silently drop the cookie.
# MINTRUD_ADMIN_COOKIE_SECURE=false

# --- Optional: SameSite cookie mode ---
# One of "lax", "strict", "none". Default "lax". Use "strict" only if
# the app is never embedded in another origin (it isn't).
# MINTRUD_ADMIN_COOKIE_SAMESITE=lax

# --- Optional: CSRF key ---
# 32 raw bytes or 64 hex chars. If unset, the app generates an
# ephemeral key on every restart — sessions then become invalid after
# a restart, which is unacceptable in production. Always set this in
# production; the same value across restarts keeps sessions alive.
# MINTRUD_ADMIN_CSRF_KEY=

# --- Optional: plaintext CSRF mode ---
# LOCAL DEV ONLY. gorilla/csrf v1.7+ rejects HTTP Referer headers as
# a downgrade attack unless the request is marked plaintext. Set this
# to "true" when running over plain HTTP (no TLS in front). Behind a
# TLS-terminating reverse proxy, the proxy's https:// scheme reaches
# the Go process unchanged and this flag must stay off — leaving it
# on in production disables the HTTPS downgrade defense.
# MINTRUD_ADMIN_PLAINTEXT_CSRF=true

# --- Optional: trusted CSRF origins ---
# Comma-separated list of origins the middleware accepts on top of
# the request's own origin. Useful when the app is fronted by a
# reverse proxy that adds an extra origin (e.g. internal sidecar).
# For plain HTTP local dev, prefer MINTRUD_ADMIN_PLAINTEXT_CSRF.
# MINTRUD_ADMIN_TRUSTED_ORIGINS=